    given-names: Ammar
    email: ammarkheder@outlook.fr
license: MIT
repository-code: "https://github.com/AmmarKheder/cran-pm"
url: "https://ammarkheder.github.io/cran-pm/"
keywords:
  - air quality
  - PM2.5
  - deep learning
  - super-resolution
  - atmospheric science
  - ERA5
  - CAMS
